[
    {"id": "SETUP_001", "action": "install_certificate", "cert_action": "install",
     "description": "Install mitmproxy CA cert into Windows trust store"},

    {"id": "SETUP_002", "action": "start_proxy",
     "listen_host": "127.0.0.1", "listen_port": 8080,
     "mode": "reverse:https://172.24.148.221:8383",
     "ssl_insecure": true,
     "description": "Start reverse proxy forwarding to real server"},

    {"id": "SETUP_003", "action": "clear_captures",
     "description": "Reset capture buffer before test"},

    {"id": "SETUP_004", "action": "modify_response",
     "url_pattern": "meta-data\\.xml",
     "inject_status": 500,
     "inject_body": "Internal Server Error",
     "persistent": true,
     "description": "Inject 500 error on meta-data.xml to test agent retry"},

    {"id": "WAIT_001", "action": "wait_for_request",
     "url_pattern": "agentSlot",
     "timeout": 120,
     "description": "Wait up to 2 min for agentSlot request"},

    {"id": "WAIT_002", "action": "wait_for_request",
     "url_pattern": "meta-data\\.xml",
     "timeout": 60,
     "continueOnFailure": true,
     "description": "Wait for meta-data.xml request"},

    {"id": "TC_001", "action": "validate_request",
     "url_pattern": "agentSlot", "method": "GET",
     "description": "agentSlot: verify method is GET"},

    {"id": "TC_002", "action": "validate_request",
     "url_pattern": "agentSlot",
     "header_name": "Authorization", "expected_value": "Basic ",
     "validation_type": "startswith",
     "description": "agentSlot: verify Basic auth header present"},

    {"id": "TC_003", "action": "validate_request",
     "url_pattern": "agentSlot",
     "header_name": "User-Agent", "expected_value": ".*",
     "validation_type": "notempty",
     "description": "agentSlot: verify User-Agent header is not empty"},

    {"id": "TC_004", "action": "validate_response",
     "url_pattern": "agentSlot",
     "expected_status": 200,
     "description": "agentSlot: verify response 200 OK"},

    {"id": "TC_005", "action": "validate_response",
     "url_pattern": "agentSlot",
     "body_pattern": ".*",
     "validation_type": "notempty",
     "continueOnFailure": true,
     "description": "agentSlot: verify response body is not empty"},

    {"id": "TC_006", "action": "validate_request",
     "url_pattern": "meta-data\\.xml", "method": "GET",
     "continueOnFailure": true,
     "description": "meta-data.xml: verify method is GET"},

    {"id": "TC_007", "action": "validate_response",
     "url_pattern": "meta-data\\.xml",
     "expected_status": 500,
     "continueOnFailure": true,
     "description": "meta-data.xml: verify injected 500 status received"},

    {"id": "TC_008", "action": "assert_request_count",
     "url_pattern": "agentSlot", "min_count": 1,
     "continueOnFailure": true,
     "description": "At least 1 agentSlot request captured"},

    {"id": "TC_009", "action": "assert_request_count",
     "url_pattern": "meta-data\\.xml", "min_count": 1,
     "continueOnFailure": true,
     "description": "At least 1 meta-data.xml request captured"},

    {"id": "TC_010", "action": "assert_request_count",
     "url_pattern": ".*", "min_count": 2, "max_count": 50,
     "continueOnFailure": true,
     "description": "Total request count between 2 and 50"},

    {"id": "TC_011", "action": "assert_request_order",
     "expected_order": ["agentSlot", "meta-data\\.xml"],
     "continueOnFailure": true,
     "description": "Verify agentSlot requested before meta-data.xml"},

    {"id": "SAVE_001", "action": "capture_traffic",
     "capture_file": "Reports/sample-test-traffic.json",
     "continueOnFailure": true,
     "description": "Save all captured traffic to report"},

    {"id": "CLEANUP_001", "action": "install_certificate", "cert_action": "remove",
     "continueOnFailure": true,
     "description": "Remove mitmproxy CA cert from trust store"},

    {"id": "CLEANUP_002", "action": "stop_proxy",
     "description": "Stop proxy cleanly"}
]
